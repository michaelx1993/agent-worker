CONTROL_PLANE_BASE_URL=http://127.0.0.1:3112
ACP_WORKER_API_TOKEN=replace-me
WORKER_ID=agent-worker-local
WORKER_RUN_LOOP=true
WORKER_LOOP_INTERVAL_MS=60000
