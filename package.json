{
  "name": "agent-worker",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "check": "pnpm -r check",
    "codex:adapter-smoke": "pnpm --filter @agent-control-plane/worker codex:adapter-smoke",
    "codex:app-server-smoke": "pnpm --filter @agent-control-plane/worker codex:app-server-smoke",
    "compose:smoke": "bash scripts/compose-smoke.sh",
    "format": "prettier --check .",
    "release:image": "bash scripts/release-image.sh",
    "release:tag": "bash scripts/release-tag.sh",
    "rollback:compose": "bash scripts/rollback-compose.sh",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "worker:contract-smoke": "pnpm --filter @agent-control-plane/worker worker:contract-smoke",
    "worker:workspace-smoke": "pnpm --filter @agent-control-plane/worker worker:workspace-smoke",
    "workspace:cleanup-smoke": "pnpm --filter @agent-control-plane/worker workspace:cleanup-smoke"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "prettier": "^3.8.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@11.0.8"
}
